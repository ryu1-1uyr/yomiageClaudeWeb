{
  "manifest_version": 3,
  "name": "Claude VOICEVOX Reader",
  "version": "0.1.0",
  "description": "claude.ai / ChatGPT / Gemini の返答を VOICEVOX / COEIROINK で自動読み上げする（自分用）",
  "permissions": ["offscreen", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "http://localhost:50021/*",
    "http://127.0.0.1:50021/*",
    "http://localhost:50032/*",
    "http://127.0.0.1:50032/*",
    "http://127.0.0.1:50090/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["adapters.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html" }
}
